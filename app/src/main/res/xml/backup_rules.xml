<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude encrypted prefs from backup — the Keystore key is device-bound
         and cannot be restored on a different device, which would make the
         database permanently inaccessible after a backup restore -->
    <exclude domain="sharedpref" path="secure_db_prefs.xml"/>
</full-backup-content>